    "P5.js":          { "github": "processing/p5.js", "npm": "p5" },
    "openFrameworks": { "github": "openframeworks/openFrameworks" },
    "Cinder":         { "github": "cinder/Cinder" },
    "Three.js":       { "github": "mrdoob/three.js", "npm": "three" },
    "D3.js":          { "github": "d3/d3", "npm": "d3" },
    "Paper.js":       { "github": "paperjs/paper.js", "npm": "paper" },
    "A-Frame":        { "github": "aframevr/aframe", "npm": "aframe" },
    "ML5.js":         { "github": "ml5js/ml5-library", "npm": "ml5" },
    "Babylon.js":     { "github": "BabylonJS/Babylon.js", "npm": "babylonjs" },
    "Svelte":         { "github": "sveltejs/svelte", "npm": "svelte" },
    "GSAP":           { "github": "greensock/GSAP", "npm": "gsap" },
    "Vega":           { "github": "vega/vega", "npm": "vega" },
    "Flutter":        { "github": "flutter/flutter" },
    "Nannou":         { "github": "nannou-org/nannou" },
