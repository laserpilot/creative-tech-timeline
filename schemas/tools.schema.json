{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Creative Code Timeline — Tools",
  "type": "object",
  "required": ["categories", "tools"],
  "properties": {
    "categories": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["name", "color"],
        "properties": {
          "name": { "type": "string" },
          "color": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
          "description": { "type": "string" }
        }
      }
    },
    "tools": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["category"],
        "properties": {
          "category": { "type": "string" },
          "description": { "type": "string" },
          "link": { "type": "string", "format": "uri" },
          "discontinued": { "type": "string", "pattern": "^\\d{4}(-\\d{2}(-\\d{2})?)?$" },
          "releases": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["dateString"],
              "properties": {
                "version": { "type": "string" },
                "dateString": { "type": "string" },
                "link": { "type": "string", "format": "uri" },
                "notes": { "type": "string" },
                "major": { "type": "boolean" }
              }
            }
          }
        }
      }
    }
  }
}
